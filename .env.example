# Remem environment configuration example
# Copy to .env and fill in values for local development.

# ── Environment gate ─────────────────────────────────────────────────────────
# Leave unset (or "development") for local/dev use — the defaults below are
# permissive on purpose so the quickstart works out of the box.
# Set to "production" before exposing this stack on any non-localhost network:
# remem-server and the backoffice will then REFUSE TO START if any secret
# below is still a placeholder, auth is disabled, or CORS is permissive —
# instead of silently serving insecurely.
REMEM_ENV=development
BACKOFFICE_ENV=development

# ── remem-server ─────────────────────────────────────────────────────────────
# API key for authenticating requests to remem-server.
# In production, always set this to a strong random value (required when
# REMEM_ENV=production; the server will refuse to start without one).
REMEM_API_KEY=

# Optional secondary key accepted alongside REMEM_API_KEY during rotation:
# add the new key here, roll out callers, then promote it to REMEM_API_KEY
# and clear this — avoids a downtime window with zero valid keys.
REMEM_API_KEY_SECONDARY=

# Only takes effect when REMEM_API_KEY is empty. Never set this when
# REMEM_ENV=production (the server refuses to start if you do).
REMEM_ALLOW_AUTH_DISABLED=false

# Comma-separated CORS origins for remem-server.
# Empty = permissive CORS (any origin) — fine for local dev, refused at
# startup when REMEM_ENV=production.
# Development: set to http://localhost:3000
# Production: set to the backoffice origin (e.g., https://backoffice.yourdomain.com)
REMEM_CORS_ORIGINS=http://localhost:3000

# Global request rate limit (requests/sec). Defaults to 100 rps / burst 50
# in code when unset — set explicitly here to override, or to 0 to disable.
# REMEM_RATE_LIMIT_RPS=100
# REMEM_RATE_LIMIT_BURST=50

# Rust log filter (trace, debug, info, warn, error).
RUST_LOG=info

# ── remem-mcp ────────────────────────────────────────────────────────────────
# URL of the remem-server REST API (used by remem-mcp).
REMEM_SERVER_URL=http://remem-server:4545

# Transport: "stdio" for CLI use, "sse" for Docker/HTTP use.
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=4546

# ── Backoffice ────────────────────────────────────────────────────────────────
# Secret for signing JWT tokens. Generate with: openssl rand -hex 32
# Required (non-placeholder, >= 32 chars) when BACKOFFICE_ENV=production.
JWT_SECRET_KEY=change-this-secret-key-in-production

# Local compose/dev bootstrap. Disable and use Alembic migrations for production.
BACKOFFICE_BOOTSTRAP_DATABASE=true
BACKOFFICE_DEFAULT_ADMIN_EMAIL=admin@example.com
# Required (changed from the default below) when BACKOFFICE_ENV=production
# and BACKOFFICE_BOOTSTRAP_DATABASE=true.
BACKOFFICE_DEFAULT_ADMIN_PASSWORD=Test1234567
BACKOFFICE_DEFAULT_ADMIN_FULL_NAME=Admin

# ── Production checklist ────────────────────────────────────────────────────
# Setting REMEM_ENV=production and BACKOFFICE_ENV=production (above) makes
# most of this enforced at startup rather than merely advisory. Still set all
# of these explicitly — the services fail fast and tell you which are missing,
# but they can't invent good secrets for you.
# Generate secrets with: openssl rand -hex 32
#
# REMEM_ENV=production
# REMEM_API_KEY=<generate with openssl rand -hex 32>
# REMEM_ALLOW_AUTH_DISABLED=false
# REMEM_CORS_ORIGINS=<production frontend origin, e.g., https://yourdomain.com>
# BACKOFFICE_ENV=production
# JWT_SECRET_KEY=<generate with openssl rand -hex 32>
# POSTGRES_PASSWORD=<strong password>
# BACKOFFICE_DEFAULT_ADMIN_PASSWORD=<strong password>
