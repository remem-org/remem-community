# Remem environment configuration example
# Copy to .env and fill in values for local development.

# ── remem-server ─────────────────────────────────────────────────────────────
# API key for authenticating requests to remem-server.
# In production, always set this to a strong random value.
REMEM_API_KEY=

# Set to "true" only in development when REMEM_API_KEY is empty.
# In production, always set REMEM_API_KEY instead.
REMEM_ALLOW_AUTH_DISABLED=true

# Comma-separated CORS origins for remem-server.
# REQUIRED for production via docker-compose.prod.yml.
# Development: set to http://localhost:3000
# Production: set to the backoffice origin (e.g., https://backoffice.yourdomain.com)
REMEM_CORS_ORIGINS=http://localhost:3000

# Rust log filter (trace, debug, info, warn, error).
RUST_LOG=info

# ── remem-mcp ────────────────────────────────────────────────────────────────
# URL of the remem-server REST API (used by remem-mcp).
REMEM_SERVER_URL=http://remem-server:8001

# Transport: "stdio" for CLI use, "sse" for Docker/HTTP use.
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8000

# ── Backoffice ────────────────────────────────────────────────────────────────
# Secret for signing JWT tokens. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-secret-key-in-production

# Local compose/dev bootstrap. Disable and use Alembic migrations for production.
BACKOFFICE_BOOTSTRAP_DATABASE=true
BACKOFFICE_DEFAULT_ADMIN_EMAIL=admin@example.com
BACKOFFICE_DEFAULT_ADMIN_PASSWORD=Test1234567
BACKOFFICE_DEFAULT_ADMIN_FULL_NAME=Admin

# ── Production-required variables ─────────────────────────────────────────────
# These must be set (non-empty) when using docker-compose.prod.yml.
# Generate with: openssl rand -hex 32
#
# REMEM_API_KEY=<generate with openssl rand -hex 32>
# JWT_SECRET_KEY=<generate with openssl rand -hex 32>
# POSTGRES_PASSWORD=<strong password>
# REMEM_CORS_ORIGINS=<production frontend origin, e.g., https://yourdomain.com>
